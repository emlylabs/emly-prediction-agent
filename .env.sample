# ── Database Configuration ─────────────────────────────────────────────
DB_HOST=localhost                 # PostgreSQL server hostname
DB_PORT=5432                     # PostgreSQL server port
DB_NAME=vectordb                 # Name of the database to connect to
POSTGRES_USER=vectoruser         # PostgreSQL authentication username
POSTGRES_PASSWORD=vectorpass     # PostgreSQL authentication password
# DB_CONNECTION_STRING=postgresql://vectoruser:vectorpass@localhost:5432/vectordb  # Alternative: full connection string (overrides individual DB_* vars)

# ── LLM Configuration ─────────────────────────────────────────────────
EMLY_SOURCE=openai               # LLM provider source (e.g., "openai", "ollama")
EMLY_MODEL=opencode/deepseek-v4-flash-free  # Model identifier to use for LLM inference
EMLY_KEY=apikey         # API key for the LLM provider
# LLM_URL=                       # Custom LLM endpoint URL (optional, defaults to provider's standard URL)
LLM_URL=https://llm.app.emlylabs.com  # Production LLM endpoint URL for the Emly Labs platform

# ── Embedding Configuration ───────────────────────────────────────────
EMBEDDING_SOURCE=huggingface     # Embedding provider source (e.g., "huggingface", "openai")
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2  # HuggingFace model for generating text embeddings
EMBEDDING_KEY=                   # API key for embedding provider (leave empty for local HuggingFace models)

# ── Vector Store ──────────────────────────────────────────────────────
VECTOR_COLLECTION_NAME=documents  # Name of the vector collection/table in the database

# ── Chunking ──────────────────────────────────────────────────────────
CHUNK_SIZE=1000                  # Maximum number of characters per text chunk for embedding
CHUNK_OVERLAP=200                # Number of overlapping characters between consecutive chunks

# ── Search ────────────────────────────────────────────────────────────
TOP_K=5                          # Number of top relevant results to retrieve from vector search

# ── Application ───────────────────────────────────────────────────────
APP_HOST=0.0.0.0                 # Host address to bind the application server (0.0.0.0 = all interfaces)
APP_PORT=8000                    # Port number for the application server
DEBUG=False                      # Enable debug mode for verbose logging and error details
